{
    "name": "@sourcegraph/scip-python",
    "version": "0.6.6",
    "description": "SCIP indexer for Python",
    "main": "index.js",
    "scripts": {
        "build": "webpack --mode production --progress",
        "bundle": "npm run build",
        "build-agent": "webpack --mode development",
        "clean": "shx rm -rf ./dist ./out README.md LICENSE.txt",
        "prepack": "npm run clean && shx cp ../../README.md . && shx cp ../../LICENSE.txt . && npm run build",
        "check-snapshots": "npm run update-snapshots -- --check",
        "update-snapshots": "node --enable-source-maps ./index-test.js",
        "test": "jest --forceExit --detectOpenHandles --no-stack-trace",
        "webpack": "webpack --mode development --progress",
        "watch": "webpack --mode development --progress --watch",
        "fix:prettier": "prettier --write --loglevel error .",
        "check:prettier": "prettier --check ."
    },
    "author": "Sourcegraph",
    "repository": {
        "type": "git",
        "url": "https://github.com/sourcegraph/scip-python",
        "directory": "packages/pyright-scip/"
    },
    "license": "MIT",
    "devDependencies": {
        "@sourcegraph/eslint-config": "0.26.0",
        "@sourcegraph/prettierrc": "3.0.3",
        "@sourcegraph/tsconfig": "4.0.1",
        "@types/command-exists": "^1.2.0",
        "@types/diff": "^5.0.2",
        "@types/glob": "^7.2.0",
        "@types/google-protobuf": "^3.15.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.19.15",
        "@types/ora": "^3.2.0",
        "clean-terminal-webpack-plugin": "^3.0.0",
        "copy-webpack-plugin": "^10.2.0",
        "jest": "^30.2.0",
        "jest-junit": "^13.0.0",
        "shx": "^0.3.3",
        "ts-jest": "^29.4.5",
        "ts-loader": "^9.2.6",
        "tsconfig-paths-webpack-plugin": "^3.5.2",
        "typescript": "~5.5.4",
        "webpack": "^5.65.0",
        "webpack-cli": "^4.9.1"
    },
    "dependencies": {
        "@iarna/toml": "^2.2.5",
        "command-exists": "^1.2.9",
        "commander": "^9.2.0",
        "diff": "^5.0.0",
        "glob": "^7.2.0",
        "google-protobuf": "^3.19.3",
        "ts-node": "^10.5.0",
        "vscode-jsonrpc": "^9.0.0-next.8",
        "vscode-languageserver": "^10.0.0-next.13",
        "vscode-languageserver-protocol": "^3.17.6-next.13",
        "vscode-languageserver-textdocument": "^1.0.12",
        "vscode-languageserver-types": "^3.17.6-next.6",
        "vscode-uri": "^3.1.0"
    },
    "files": [
        "/dist",
        "LICENSE.txt"
    ],
    "bin": {
        "scip-python": "index.js"
    }
}
